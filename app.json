{
  "expo": {
    "name": "mail-app",
    "slug": "mail-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mailapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "appleTeamId": "H2X8YGN869",
      "bundleIdentifier": "com.jash.mail-app",
      "deploymentTarget": "16.0",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.jash.mailapp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.510423566915-edi6sd1aqhcs4flbbcsdht22sfre9tsf"
        }
      ],
      "expo-secure-store",
      "expo-sqlite",
      "expo-audio",
      "react-native-nitro-archive",
      [
        "./plugins/withMinDeploymentTarget",
        "16.0"
      ],
      "llama.rn",
      [
        "@sentry/react-native/expo",
        {
          "organization": "raccoon-software",
          "project": "mail-app"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "819257c5-1d8c-496d-92ca-e39a8f3524b0"
      }
    }
  }
}
