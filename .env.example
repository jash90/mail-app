# ── Cloud AI backend ────────────────────────────────────────────────
# Choose cloud provider: 'zai' (default) or 'openrouter'
EXPO_PUBLIC_AI_BACKEND=zai

# Z.AI (ZhipuAI GLM models)
# WARNING: EXPO_PUBLIC_ vars are bundled into JS — do not use production keys
EXPO_PUBLIC_ZAI_API_KEY=
EXPO_PUBLIC_ZAI_MODEL=glm-4-flashx

# OpenRouter (access 200+ models: openrouter.ai)
EXPO_PUBLIC_OPENROUTER_API_KEY=
EXPO_PUBLIC_OPENROUTER_MODEL=qwen/qwen3.6-plus:free

# ── AI Token Tracking ────────────────────────────────────────────────
# Enable token usage tracking and statistics ("true" to enable)
EXPO_PUBLIC_AI_TOKEN_TRACKING=false

# ── Local AI models ─────────────────────────────────────────────────
# Enable on-device local AI models (llama.rn). Set to "true" to show in settings.
EXPO_PUBLIC_LOCAL_MODELS_ENABLED=false

# Google Sign-In reversed client ID (iOS URL scheme)
# Get this from Google Cloud Console → OAuth 2.0 Client IDs → iOS client
GOOGLE_IOS_URL_SCHEME=
