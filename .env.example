# Z.AI API key for email summarization
# WARNING: EXPO_PUBLIC_ vars are bundled into JS — do not use production keys
EXPO_PUBLIC_ZAI_API_KEY=

# Enable on-device local AI models (llama.rn). Set to "true" to show in settings.
EXPO_PUBLIC_LOCAL_MODELS_ENABLED=false

# Google Sign-In reversed client ID (iOS URL scheme)
# Get this from Google Cloud Console → OAuth 2.0 Client IDs → iOS client
GOOGLE_IOS_URL_SCHEME=
