---
const showOnDeviceAI = import.meta.env.SHOW_ON_DEVICE_AI === "true";

const cards = [
  ...(showOnDeviceAI ? [{
    icon: `<svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 2a4 4 0 0 1 4 4c0 1.95-1.4 3.58-3.25 3.93L12 22l-.75-12.07A4.001 4.001 0 0 1 12 2Z" stroke-linecap="round" stroke-linejoin="round"/><path d="M8 16h8" stroke-linecap="round"/></svg>`,
    title: "On-Device AI",
    description: "Run Llama 3.2, Bielik, or Qwen 3 locally with Metal GPU acceleration. Your data never leaves your phone.",
  }] : [{
    icon: `<svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 2a4 4 0 0 1 4 4c0 1.95-1.4 3.58-3.25 3.93L12 22l-.75-12.07A4.001 4.001 0 0 1 12 2Z" stroke-linecap="round" stroke-linejoin="round"/><path d="M8 16h8" stroke-linecap="round"/></svg>`,
    title: "AI Summaries",
    description: "Cloud AI distills long email threads into concise summaries so you can triage your inbox faster.",
  }]),
  {
    icon: `<svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 18.5a6.5 6.5 0 1 0 0-13 6.5 6.5 0 0 0 0 13Z" stroke-linecap="round"/><path d="M12 2v2m0 16v2M2 12h2m16 0h2" stroke-linecap="round"/><circle cx="12" cy="12" r="2"/></svg>`,
    title: "Offline TTS",
    description: "Listen to your email with Sherpa ONNX text-to-speech. Works offline in English and Polish.",
  },
  {
    icon: `<svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 7V4h16v3M9 20h6M12 4v16" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    title: "SQLite + FTS5",
    description: "Full-text search over your entire inbox using SQLite with WAL mode and BM25 reranking.",
  },
  {
    icon: `<svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    title: "Privacy-First",
    description: showOnDeviceAI
      ? "OAuth tokens encrypted with SecureStore. AI runs on-device. No third-party data sharing."
      : "OAuth tokens encrypted with SecureStore. Secure authentication. No third-party data sharing.",
  },
  {
    icon: `<svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 18a6 6 0 1 0 0-12 6 6 0 0 0 0 12Z"/><path d="M12 2v4m0 12v4M2 12h4m12 0h4" stroke-linecap="round"/></svg>`,
    title: "React Native",
    description: "Built with Expo SDK 54, React 19, and the New Architecture for native performance.",
  },
  {
    icon: `<svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M16 18l6-6-6-6M8 6l-6 6 6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    title: "Open Architecture",
    description: "Drizzle ORM, Zustand stores, React Query caching, and modular feature directories.",
  },
];
---

<section id="tech" class="px-6 py-20 lg:py-28">
  <div class="mx-auto max-w-6xl">
    <div class="mb-12 text-center">
      <span
        class="mb-4 inline-block rounded-full border border-accent-1/30 bg-accent-1/10 px-3 py-1 text-xs font-medium text-accent-1"
      >
        Under the Hood
      </span>
      <h2 class="text-3xl font-bold tracking-tight text-text-primary sm:text-4xl">
        Built for power users
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-text-secondary">
        A modern stack designed for speed, privacy, and offline reliability.
      </p>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {cards.map((card) => (
        <div class="group rounded-2xl border border-border-subtle bg-bg-card p-6 transition-colors hover:border-accent-1/30 hover:bg-bg-card-hover">
          <div class="mb-4 inline-flex rounded-xl bg-accent-1/10 p-3 text-accent-1">
            <Fragment set:html={card.icon} />
          </div>
          <h3 class="mb-2 text-lg font-semibold text-text-primary">{card.title}</h3>
          <p class="text-sm leading-relaxed text-text-secondary">{card.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
