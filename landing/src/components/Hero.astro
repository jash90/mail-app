---
const showOnDeviceAI = import.meta.env.SHOW_ON_DEVICE_AI === "true";
---

<section class="relative overflow-hidden px-6 pt-32 pb-20 lg:pt-40 lg:pb-28">
  <div
    class="pointer-events-none absolute inset-0 -z-10"
    style="background: radial-gradient(ellipse 60% 50% at 50% 0%, rgba(99, 102, 241, 0.12), transparent);"
  >
  </div>

  <div class="mx-auto flex max-w-6xl flex-col items-center gap-12 lg:flex-row lg:gap-16">
    <div class="flex-1 text-center lg:text-left">
      <h1
        class="animate-fade-up text-4xl font-bold leading-tight tracking-tight text-text-primary sm:text-5xl lg:text-6xl"
      >
        Your inbox,<br />
        <span
          class="bg-gradient-to-r from-accent-1 to-accent-2 bg-clip-text text-transparent"
        >
          understood.
        </span>
      </h1>

      <p
        class="animate-fade-up animate-delay-100 mx-auto mt-6 max-w-lg text-lg leading-relaxed text-text-secondary lg:mx-0"
      >
        {showOnDeviceAI
          ? "An AI-powered email client that summarizes, analyzes, and speaks your email — all on-device. No cloud. No compromise."
          : "An AI-powered email client that summarizes, analyzes, and speaks your email — intelligently and privately."}
      </p>

      <div class="animate-fade-up animate-delay-200 mt-8 flex flex-col items-center gap-4 sm:flex-row lg:justify-start">
        <a
          href="#download"
          class="inline-flex items-center rounded-full bg-gradient-to-r from-accent-1 to-accent-2 px-8 py-3.5 text-base font-semibold text-white shadow-lg shadow-accent-1/25 transition-all hover:shadow-accent-1/40 hover:brightness-110"
        >
          Get the App
        </a>
        <a
          href="#features"
          class="inline-flex items-center gap-2 rounded-full border border-border-subtle px-8 py-3.5 text-base font-medium text-text-secondary transition-colors hover:border-text-secondary hover:text-text-primary"
        >
          See Features
          <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M19 9l-7 7-7-7" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </a>
      </div>
    </div>

    <div class="animate-fade-up animate-delay-300 flex-shrink-0">
      <div class="phone-frame">
        <img
          src="/screenshots/inbox.png"
          alt="Mail App inbox showing email threads with AI summary playback"
          width="272"
          height="590"
          loading="eager"
        />
      </div>
    </div>
  </div>
</section>
